      "name": "vllm",
      "type": "vllm-managed",
      "command": "vllm",
      "bench_command": "vllm"
    }
  ],
  "runner": {
    "vllm_command": "/home/bob/runtimes/vllm/current/.venv/bin/vllm",
    "vllm_bench_command": "/home/bob/runtimes/vllm/current/.venv/bin/vllm",
    "one_awake_profile": true,
    "preboot_profiles": false,
    "stop_managed_on_exit": true,
    "append_timestamp_to_run": false
