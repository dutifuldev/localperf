{
  "version": "2",
  "name": "ShareGPT Chat Smoke",
  "description": "One-sample ShareGPT chat smoke benchmark for the canonical dataset pipeline.",
  "model": "nvidia/diffusiongemma-26B-A4B-it-NVFP4",
  "output_dir": "runs",
  "runner": {
    "append_timestamp_to_run": false,
    "stop_managed_on_exit": true
  },
  "safety": {
    "min_mem_available_gib": 40,
    "startup_timeout_sec": 900,
    "workload_timeout_sec": 600,
    "poll_interval_millis": 1000
  },
  "profiles": [
    {
      "name": "smoke",
      "port": 8101,
      "managed": true,
      "max_model_len": 4096,
      "max_num_seqs": 1,
      "max_num_batched_tokens": 4096,
      "gpu_memory_utilization": 0.4
    }
  ],
  "workloads": [
    {
      "name": "sharegpt-chat-smoke",
      "phase": "decode",
      "context_target": 4096,
      "context_semantics": "capacity",
      "profiles": [
        "smoke"
      ],
      "capture_payload_artifacts": true,
      "dataset": {
        "type": "sharegpt",
        "path": "examples/sharegpt-chat-smoke/data/sharegpt.json",
        "split": "train",
        "sample_count": 1,
        "seed": 1,
        "selection": "first_n"
      },
      "request": {
        "mode": "chat",
        "turn_policy": "first_user_turn",
        "max_output_tokens": 512,
        "temperature": 0,
        "ignore_eos": false
      },
      "load": {
        "max_concurrency": [
          1
        ],
        "request_rate": "inf"
      }
    }
  ]
}
