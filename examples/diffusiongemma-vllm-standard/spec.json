{
  "version": "1",
  "name": "diffusiongemma-vllm-standard",
  "description": "Standard LocalPerf vLLM benchmark profile for nvidia/diffusiongemma-26B-A4B-it-NVFP4 on the DGX Spark/GB10-class local machine.",
  "model": "nvidia/diffusiongemma-26B-A4B-it-NVFP4",
  "output_dir": "runs",
  "env": {
    "CUTE_DSL_ARCH": "sm_121a",
    "FLASHINFER_DISABLE_VERSION_CHECK": "1",
    "VLLM_USE_V2_MODEL_RUNNER": "1"
  },
  "runner": {
    "vllm_command": "vllm",
    "vllm_bench_command": "vllm",
    "one_awake_profile": true,
    "preboot_profiles": false,
    "stop_managed_on_exit": true
  },
  "safety": {
    "min_mem_available_gib": 40,
    "poll_interval_millis": 1000,
    "startup_timeout_sec": 900,
    "workload_timeout_sec": 2400,
    "http_timeout_sec": 15
  },
  "warmup": {
    "enabled": true,
    "dataset_name": "random",
    "backend": "openai-chat",
    "random_input_len": 256,
    "random_output_len": 16,
    "num_prompts": 4,
    "max_concurrency": 1,
    "request_rate": "inf"
  },
  "profiles": [
    {
      "name": "4k-reference",
      "host": "127.0.0.1",
      "port": 8104,
      "managed": true,
      "enable_sleep_mode": true,
      "sleep_level": 2,
      "max_model_len": 4096,
      "max_num_seqs": 20,
      "max_num_batched_tokens": 8192,
      "gpu_memory_utilization": 0.3,
      "attention_backend": "TRITON_ATTN",
      "moe_backend": "cutlass",
      "args": [
        "--default-chat-template-kwargs",
        "{\"enable_thinking\":false}",
        "--no-enable-log-requests",
        "--no-enable-flashinfer-autotune"
      ]
    },
    {
      "name": "8k",
      "host": "127.0.0.1",
      "port": 8108,
      "managed": true,
      "enable_sleep_mode": true,
      "sleep_level": 2,
      "max_model_len": 8192,
      "max_num_seqs": 16,
      "max_num_batched_tokens": 8192,
      "gpu_memory_utilization": 0.35,
      "attention_backend": "TRITON_ATTN",
      "moe_backend": "cutlass",
      "args": [
        "--default-chat-template-kwargs",
        "{\"enable_thinking\":false}",
        "--no-enable-log-requests",
        "--no-enable-flashinfer-autotune"
      ]
    },
    {
      "name": "16k",
      "host": "127.0.0.1",
      "port": 8116,
      "managed": true,
      "enable_sleep_mode": true,
      "sleep_level": 2,
      "max_model_len": 16384,
      "max_num_seqs": 16,
      "max_num_batched_tokens": 8192,
      "gpu_memory_utilization": 0.25,
      "attention_backend": "TRITON_ATTN",
      "moe_backend": "cutlass",
      "args": [
        "--default-chat-template-kwargs",
        "{\"enable_thinking\":false}",
        "--no-enable-log-requests",
        "--no-enable-flashinfer-autotune"
      ]
    },
    {
      "name": "32k",
      "host": "127.0.0.1",
      "port": 8132,
      "managed": true,
      "enable_sleep_mode": true,
      "sleep_level": 2,
      "max_model_len": 32768,
      "max_num_seqs": 16,
      "max_num_batched_tokens": 8192,
      "gpu_memory_utilization": 0.2,
      "attention_backend": "TRITON_ATTN",
      "moe_backend": "cutlass",
      "args": [
        "--default-chat-template-kwargs",
        "{\"enable_thinking\":false}",
        "--no-enable-log-requests",
        "--no-enable-flashinfer-autotune"
      ]
    }
  ],
  "workloads": [
    {
      "name": "claim-repro-1k-out1024",
      "profiles": ["4k-reference"],
      "backend": "openai-chat",
      "dataset_name": "random",
      "random_input_len": 1000,
      "random_output_len": 1024,
      "num_prompts": 20,
      "max_concurrency": [1, 4, 20],
      "request_rate": "inf",
      "ignore_eos": true,
      "temperature": 0
    },
    {
      "name": "decode-1k-out512-fixed",
      "profiles": ["8k", "16k", "32k"],
      "backend": "openai-chat",
      "dataset_name": "random",
      "random_input_len": 1024,
      "random_output_len": 512,
      "num_prompts": 64,
      "max_concurrency": [4, 8, 16],
      "request_rate": "inf",
      "ignore_eos": true,
      "temperature": 0
    },
    {
      "name": "prefill-8k-out16-fixed",
      "profiles": ["8k", "16k", "32k"],
      "backend": "openai-chat",
      "dataset_name": "random",
      "random_input_len": 7168,
      "random_output_len": 16,
      "num_prompts": 64,
      "max_concurrency": [1, 4, 8, 16],
      "request_rate": "inf",
      "ignore_eos": true,
      "temperature": 0
    },
    {
      "name": "prefill-16k-out16-fixed",
      "profiles": ["16k", "32k"],
      "backend": "openai-chat",
      "dataset_name": "random",
      "random_input_len": 14336,
      "random_output_len": 16,
      "num_prompts": 64,
      "max_concurrency": [1, 4, 8, 16],
      "request_rate": "inf",
      "ignore_eos": true,
      "temperature": 0
    },
    {
      "name": "prefill-32k-out16-fixed",
      "profiles": ["32k"],
      "backend": "openai-chat",
      "dataset_name": "random",
      "random_input_len": 28672,
      "random_output_len": 16,
      "num_prompts": 64,
      "max_concurrency": [1, 4, 8, 16],
      "request_rate": "inf",
      "ignore_eos": true,
      "temperature": 0
    }
  ]
}
